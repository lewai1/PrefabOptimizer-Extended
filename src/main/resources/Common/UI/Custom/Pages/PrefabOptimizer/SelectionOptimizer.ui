$C = "../../Common.ui";

@PrimaryButton = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: (FontSize: 13, TextColor: #f4efe1, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds
);

@Panel = #1f2529(0.78);
@Line = #8f7f45(0.40);
@Gold = #c8b56f;
@SoftText = #d8d0b4;

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 560, Height: 420);

    #Title {
      $C.@Title {
        @Text = "Selection Optimizer";
      }
      TextButton #CloseButton {
        Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
        Padding: (Left: 8, Top: 2);
        Text: "Close";
        Style: TextButtonStyle(
          Default: (LabelStyle: (FontSize: 14, TextColor: #93844c, RenderBold: true)),
          Sounds: $C.@ButtonSounds
        );
        Background: #000000(0.13);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 18);

      Group #Body {
        LayoutMode: Top;
        FlexWeight: 1;
        Padding: (Full: 14);
        Background: @Panel;

        Label {
          Text: "Optimizes your current BuilderTools selection. The edit is queued through BuilderTools, so /undo can revert it.";
          Style: (FontSize: 14, TextColor: @SoftText);
          Anchor: (Height: 48);
        }

        Panel { Anchor: (Height: 1); Background: @Line; }
        Panel { Anchor: (Height: 14); Background: #000000(0); }

        Label {
          Text: "Optimizer Settings";
          Style: (FontSize: 17, TextColor: @Gold, RenderBold: true);
          Anchor: (Height: 28);
        }

        Group { LayoutMode: Left; Anchor: (Height: 32);
          $C.@CheckBox #PreserveTransparent { Anchor: (Width: 28, Height: 28); Value: true; }
          Label { Text: "Preserve transparent / non-opaque blocks"; Style: (FontSize: 13, TextColor: @SoftText); FlexWeight: 1; }
        }

        Group { LayoutMode: Left; Anchor: (Height: 32);
          $C.@CheckBox #StrictCubeOnly { Anchor: (Width: 28, Height: 28); Value: true; }
          Label { Text: "Default mode: only remove DrawType.Cube blocks"; Style: (FontSize: 13, TextColor: @SoftText); FlexWeight: 1; }
        }

        Label {
          Text: "Exclude blocks by regex, or comma-separated text tokens";
          Style: (FontSize: 12, TextColor: #9ab2bc);
          Anchor: (Height: 22, Top: 8);
        }

        $C.@TextField #ExcludedBlocks {
          Anchor: (Height: 36);
          PlaceholderText: "Example: ^UnstableRifts_|Glass|Water";
          PlaceholderStyle: (TextColor: #586971, FontSize: 12);
        }

        Panel { Anchor: (Height: 18); Background: #000000(0); }

        TextButton #OptimizeSelectionButton {
          Anchor: (Height: 36);
          Text: "Optimize Selection";
          Style: @PrimaryButton;
        }
      }

      Label #StatusLabel {
        Text: "";
        Style: (FontSize: 12, TextColor: #9ab2bc);
        Anchor: (Height: 32, Top: 8);
      }
    }
  }
}
